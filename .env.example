# ─── DataForSEO (keyword discovery, difficulty, intent, rank tracking) ───────
# A single prepaid DataForSEO account. The Labs endpoints used here need no
# separate plan. https://dataforseo.com
DATAFORSEO_LOGIN=your_dataforseo_login
DATAFORSEO_PASSWORD=your_dataforseo_password

# ─── Google Sheets (content calendar, rank history, cost log) ────────────────
# The spreadsheet ID from its URL: docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=your_google_sheet_id
# Service-account JSON on a SINGLE line. Share the sheet with the service
# account's client_email (Editor). The same account is reused for GSC below.
GOOGLE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"...@....iam.gserviceaccount.com"}

# ─── LLM (OpenAI-compatible chat completions for article generation) ─────────
# Works with OpenAI or any OpenAI-compatible endpoint (Moonshot, Together, Groq…).
LLM_API_KEY=your_llm_api_key
# Base URL for chat completions (default: https://api.openai.com/v1)
LLM_BASE_URL=https://api.openai.com/v1
# Chat model used for titles, body, and meta descriptions (default: gpt-4o)
LLM_MODEL=gpt-4o
# Image model for featured images. Uses OpenAI's image endpoint directly and
# reuses LLM_API_KEY (default: gpt-image-1)
IMAGE_MODEL=gpt-image-1

# ─── Webflow CMS (optional — only needed to publish articles) ────────────────
WEBFLOW_TOKEN=your_webflow_api_token
WEBFLOW_SITE_ID=your_webflow_site_id
WEBFLOW_COLLECTION_ID=your_webflow_posts_collection_id

# ─── Google Search Console (optional — real query metrics in the Grow view) ──
# Add the GOOGLE_SERVICE_ACCOUNT client_email as a user on the GSC property.
# Leave blank to auto-detect from SITE_DOMAIN (sc-domain: and https:// forms).
GSC_PROPERTY=

# ─── Branding / site config (genericizes the app for your own brand) ─────────
# Brand name shown in the UI and used in the LLM writing voice (default: Acme)
BRAND_NAME=Acme
# The site you publish/track for, bare host, no protocol (default: example.com)
SITE_DOMAIN=example.com
# Canonical https origin (default: https://www.${SITE_DOMAIN})
SITE_URL=https://www.example.com
# Section/blog label used in breadcrumbs (default: "${BRAND_NAME} Blog")
BLOG_NAME=Acme Blog
# Comma-separated example seed topics shown as one-click chips on Explore
SUGGESTED_TOPICS=content marketing,email automation,seo basics,landing page design

# Default domain the Grow view tracks (default: SITE_DOMAIN)
GROW_DOMAIN=example.com

# Expose brand/domain to the browser UI (client component). Mirror the values
# above so the sidebar/settings render your brand. Without these the UI falls
# back to "Acme" / "example.com".
NEXT_PUBLIC_BRAND_NAME=Acme
NEXT_PUBLIC_SITE_DOMAIN=example.com
